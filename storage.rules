rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImageSize() {
      // Max 10MB for images
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isValidImage() {
      return request.resource != null &&
             request.resource.contentType != null &&
             request.resource.contentType.matches('image/.*');
    }

    // User profile pictures
    match /users/{userId}/profile/{imageId} {
      allow read: if true; // Public read
      allow write: if isOwner(userId) && isValidImage() && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    // Meal images (for AI analysis) - TEMPORARILY PERMISSIVE FOR DEBUGGING
    match /users/{userId}/meals/{allFiles=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Group images
    match /groups/{groupId}/images/{imageId} {
      allow read: if true; // Public read for group images
      allow write: if isAuthenticated() && isValidImage() && isValidImageSize();
      allow delete: if isAuthenticated(); // Creator check should be in app logic
    }

    // Group post media (images and videos)
    match /groups/{groupId}/posts/{postId}/{mediaFile} {
      allow read: if true; // Public read for public groups, Firestore rules handle privacy
      allow write: if isAuthenticated() &&
                     request.resource.size < 10 * 1024 * 1024 && // Max 10MB
                     (request.resource.contentType.matches('image/.*') ||
                      request.resource.contentType.matches('video/.*'));
      allow delete: if isAuthenticated(); // Author/creator check in app logic
    }

    // Recipe media (admin-uploaded marketing images/videos)
    match /recipes/media/{recipeId}/{mediaFile} {
      allow read: if true; // Public read for recipe images
      allow write: if isAuthenticated() && isValidImageSize();
      allow delete: if isAuthenticated(); // Admin check should be in app logic
    }

    // Patient documents (insurance cards, medical records, etc.)
    match /documents/{patientId}/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.size < 20 * 1024 * 1024; // Max 20MB
      allow delete: if isAuthenticated();
    }

    // Medication images (scanned medication bottles)
    match /medications/{userId}/{patientId}/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidImage() && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    // Health episode photos (progress, injury recovery, abuse documentation)
    match /health-episodes/{userId}/{patientId}/{episodeId}/{imageId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) &&
                     request.resource.size < 20 * 1024 * 1024 &&
                     request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }

    // Job application resumes
    match /resumes/{applicationId}/{fileName} {
      allow read: if isAuthenticated(); // Admins and applicants can read
      allow write: if request.resource.size < 10 * 1024 * 1024 && // Max 10MB
                     (request.resource.contentType == 'application/pdf' ||
                      request.resource.contentType == 'application/msword' ||
                      request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' ||
                      request.resource.contentType == 'text/plain');
      allow delete: if isAuthenticated(); // Admin can delete
    }

    // Admin perk images (sponsor perks system)
    match /admin/perks/{imageId} {
      allow read: if true; // Public read for perk images
      allow write: if isAuthenticated() && isValidImage() &&
                     request.resource.size < 5 * 1024 * 1024; // Max 5MB
      allow delete: if isAuthenticated(); // Admin delete
    }

    // Admin partner logos (sponsor perks system)
    match /admin/partners/{imageId} {
      allow read: if true; // Public read for partner logos
      allow write: if isAuthenticated() && isValidImage() &&
                     request.resource.size < 2 * 1024 * 1024; // Max 2MB
      allow delete: if isAuthenticated(); // Admin delete
    }

    // Ad background images (admin marketing)
    match /ads/backgrounds/{imageId} {
      allow read: if true; // Public read for ad backgrounds
      allow write: if isAuthenticated() && isValidImage() &&
                     request.resource.size < 5 * 1024 * 1024; // Max 5MB
      allow delete: if isAuthenticated();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
